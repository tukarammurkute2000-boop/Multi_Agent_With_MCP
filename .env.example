# ============================================================
# AI Travel Planning & Booking System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys.
# Never commit .env to version control.

# ─── Anthropic (Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Flight APIs ─────────────────────────────────────────────
# Amadeus (https://developers.amadeus.com)
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com   # use prod.api.amadeus.com in production

# ─── Hotel APIs ──────────────────────────────────────────────
# Amadeus Hotel Search (same credentials as flight)
HOTEL_SEARCH_RADIUS=5          # km radius from city center
HOTEL_MAX_RESULTS=20

# ─── Maps & Distance ─────────────────────────────────────────
# Google Maps Platform (https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_DISTANCE_MATRIX_URL=https://maps.googleapis.com/maps/api/distancematrix/json

# ─── Payment ─────────────────────────────────────────────────
# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_CURRENCY=INR
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Vector Database (RAG) ───────────────────────────────────
# Pinecone (https://app.pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=travel-knowledge-base

# ─── Redis (Memory Graph + Atomic Locking) ───────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                 # leave blank for local dev
REDIS_DB=0
REDIS_LOCK_TIMEOUT=30           # seconds
REDIS_SESSION_TTL=86400         # 24 hours

# ─── Persistent Storage ──────────────────────────────────────
DATABASE_URL=sqlite:///./travel_system.db   # swap for postgres in prod
# DATABASE_URL=postgresql://user:password@localhost:5432/travel_db

# ─── MCP Server ──────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_SECRET_KEY=your_mcp_secret_key_min_32_chars
MCP_CIRCUIT_BREAKER_THRESHOLD=5
MCP_CIRCUIT_BREAKER_TIMEOUT=60

# ─── Train Booking (RailAPI via RapidAPI) ────────────────────
# https://rapidapi.com/indianrailways/api/indian-railway1
RAILAPI_KEY=your_rapidapi_key_for_railapi
RAILAPI_BASE_URL=https://indian-railway1.p.rapidapi.com

# ─── Bus Booking (RedBus via RapidAPI) ───────────────────────
# https://rapidapi.com/redbus/api/redbus
REDBUS_API_KEY=your_rapidapi_key_for_redbus
REDBUS_BASE_URL=https://redbus.p.rapidapi.com

# ─── Weather API (optional, for itinerary realism) ───────────
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ─── App Config ──────────────────────────────────────────────
APP_ENV=development             # development | staging | production
LOG_LEVEL=INFO
MAX_ITINERARY_RETRIES=3
HUMAN_IN_LOOP_TIMEOUT=300       # seconds to wait for user confirmation
